<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="48dp">

        <TextView
            android:id="@+id/tvThreadInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="16dp"
            android:text="Информация о потоке"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/etLessons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Введите общее количество пар за месяц"
            android:inputType="number" />

        <EditText
            android:id="@+id/etDays"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Введите количество учебных дней"
            android:inputType="number" />

        <Button
            android:id="@+id/buttonCalc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Рассчитать в фоновом потоке" />

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Результат появится здесь"
            android:textSize="18sp" />

    </LinearLayout>
</ScrollView>