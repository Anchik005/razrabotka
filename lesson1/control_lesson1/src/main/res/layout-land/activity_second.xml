<?xml version="1.0" encoding="utf-8"?>
<TableLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:stretchColumns="0,1"
    android:padding="16dp">

    <!-- Поле ввода сверху на всю ширину -->
    <TableRow
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <EditText
            android:id="@+id/editTextText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_span="2"
            android:minHeight="48dp"
            android:padding="12dp"
            android:hint="New life for mirea activity!"
            android:inputType="text" />
    </TableRow>

    <!-- 1 ряд кнопок -->
    <TableRow
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp">

        <Button
            android:id="@+id/btn1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#E0E0E0"
            android:text="ПЕРВАЯ КНОПКА"
            android:textColor="#666666"
            app:cornerRadius="3dp" />

        <Button
            android:id="@+id/btn2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:backgroundTint="#E0E0E0"
            android:text="ВТОРАЯ КНОПКА"
            android:textColor="#666666"
            app:cornerRadius="3dp" />
    </TableRow>

    <!-- 2 ряд кнопок -->
    <TableRow
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp">

        <Button
            android:id="@+id/btn3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#E0E0E0"
            android:text="ТРЕТЬЯ КНОПКА"
            android:textColor="#666666"
            app:cornerRadius="3dp" />

        <Button
            android:id="@+id/btn4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:backgroundTint="#E0E0E0"
            android:text="ЧЕТВЁРТАЯ КНОПКА"
            android:textColor="#666666"
            app:cornerRadius="3dp" />
    </TableRow>

    <!-- 3 ряд кнопок -->
    <TableRow
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp">

        <Button
            android:id="@+id/btn5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#E0E0E0"
            android:text="ПЯТАЯ КНОПКА"
            android:textColor="#666666"
            app:cornerRadius="3dp" />

        <Button
            android:id="@+id/btn6"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:backgroundTint="#E0E0E0"
            android:text="ШЕСТАЯ КНОПКА"
            android:textColor="#666666"
            app:cornerRadius="3dp" />
    </TableRow>

</TableLayout>